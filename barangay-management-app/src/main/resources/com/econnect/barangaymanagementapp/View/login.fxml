<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="666.0" prefWidth="1096.0" styleClass="background" stylesheets="@../Style/login.css"
            xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.econnect.barangaymanagementapp.Controller.LoginController">
    <children>
        <VBox alignment="TOP_CENTER" layoutX="632.0" layoutY="64.0" maxHeight="-Infinity" maxWidth="-Infinity"
              prefHeight="462.0" prefWidth="357.0" spacing="50.0" styleClass="login-container"
              AnchorPane.bottomAnchor="87.0" AnchorPane.rightAnchor="107.0" AnchorPane.topAnchor="64.0">
            <children>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="LOGIN" wrappingWidth="94.13671875">
                    <font>
                        <Font name="Arial Bold" size="28.0"/>
                    </font>
                </Text>
                <Text fx:id="errorLabel" fill="RED" strokeType="OUTSIDE" strokeWidth="0.0"
                      text="Invalid username or password.">
                    <font>
                        <Font name="Arial" size="14.0"/>
                    </font>
                </Text>
                <TextField fx:id="usernameInput" prefHeight="35.0" prefWidth="300.0" promptText="Username"
                           styleClass="login-input">
                    <font>
                        <Font name="Arial" size="16.0"/>
                    </font>
                    <padding>
                        <Insets left="10.0" right="10.0"/>
                    </padding>
                </TextField>
                <PasswordField fx:id="passwordInput" prefHeight="35.0" prefWidth="300.0" promptText="Password"
                               styleClass="login-input">
                    <font>
                        <Font name="Arial" size="16.0"/>
                    </font>
                    <padding>
                        <Insets left="10.0" right="10.0"/>
                    </padding>
                </PasswordField>
                <Button fx:id="loginBtn" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="35.0"
                        prefWidth="300.0" styleClass="login-btn" text="Login" textFill="WHITE"
                        onMouseClicked="#handleLoginButton">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Button>
            </children>
            <padding>
                <Insets bottom="45.0" left="60.0" right="60.0" top="45.0"/>
            </padding>
        </VBox>
        <ImageView fx:id="closeBtn" fitHeight="16.0" fitWidth="18.0" layoutX="1066.0" layoutY="14.0" pickOnBounds="true"
                   preserveRatio="true" styleClass="exit-btn" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0"
                   onMouseClicked="#handleCloseButton">
            <image>
                <Image url="@../Icons/close.png"/>
            </image>
        </ImageView>
    </children>
</AnchorPane>
