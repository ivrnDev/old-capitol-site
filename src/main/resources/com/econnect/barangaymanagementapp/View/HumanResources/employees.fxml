<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane stylesheets="@../../Style/Components/button.css" xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.econnect.barangaymanagementapp.Controller.HumanResources.EmployeeController">
    <top>
        <fx:include fx:id="header" source="../Component/header.fxml"/>
    </top>
    <left>
        <fx:include fx:id="sidebar" source="../Component/sidebar.fxml"/>
    </left>
    <center>
        <VBox fx:id="content" prefHeight="600.0" prefWidth="1080.0" spacing="30.0" BorderPane.alignment="CENTER">
            <children>
                <AnchorPane>
                    <children>
                        <Button mnemonicParsing="false" styleClass="add" text="Add Employee"
                                AnchorPane.leftAnchor="0.0">
                            <font>
                                <Font name="Arial" size="12.0"/>
                            </font>
                        </Button>
                        <HBox alignment="CENTER_LEFT" layoutX="856.0" layoutY="-2.0" styleClass="search-box"
                              stylesheets="@../../Style/Components/search.css" AnchorPane.rightAnchor="0.0">
                            <children>
                                <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../../Icon/search.png"/>
                                    </image>
                                </ImageView>
                                <TextField promptText="Search" HBox.hgrow="ALWAYS">
                                    <font>
                                        <Font name="Arial" size="12.0"/>
                                    </font>
                                </TextField>
                            </children>
                            <opaqueInsets>
                                <Insets/>
                            </opaqueInsets>
                            <padding>
                                <Insets bottom="2.0" left="10.0" right="2.0" top="2.0"/>
                            </padding>
                        </HBox>
                    </children>
                </AnchorPane>
                <fx:include fx:id="table" source="../Component/table.fxml"/>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>

        </VBox>
    </center>

</BorderPane>
