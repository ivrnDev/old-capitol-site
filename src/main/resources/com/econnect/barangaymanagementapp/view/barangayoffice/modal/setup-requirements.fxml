<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="rootContainer" prefHeight="334.0" prefWidth="501.0" styleClass="panel"
            stylesheets="@../../../style/component/customize-modal.css" xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.econnect.barangaymanagementapp.controller.barangayoffice.modal.SetupRequirementsController">
    <children>
        <Text fill="#414141" layoutX="20.0" layoutY="45.0" strokeType="OUTSIDE" strokeWidth="0.0" text="NBI Clearance">
            <font>
                <Font name="Arial" size="24.0"/>
            </font>
        </Text>
        <VBox alignment="CENTER" layoutX="132.0" layoutY="75.0" prefHeight="154.0" prefWidth="238.0" spacing="30.0">
            <children>
                <HBox fx:id="uploadClearance" alignment="CENTER_LEFT" prefWidth="239.0" spacing="10.0"
                      styleClass="file-chooser">
                    <children>
                        <ImageView fitHeight="38.0" fitWidth="38.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../../../icon/upload-image.png"/>
                            </image>
                        </ImageView>
                        <Label fx:id="clearanceLabel" text="NBI Clearance" textFill="#686464">
                            <font>
                                <Font name="Arial" size="15.0"/>
                            </font>
                        </Label>
                    </children>
                    <padding>
                        <Insets bottom="2.0" left="10.0" right="10.0" top="2.0"/>
                    </padding>
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </HBox>
                <DatePicker fx:id="nbiExpirationInput" prefHeight="44.0" prefWidth="240.0"
                            promptText="NBI Expiration Date" styleClass="date-picker">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </DatePicker>
            </children>
        </VBox>
        <HBox alignment="CENTER_RIGHT" layoutX="210.0" layoutY="266.0" prefHeight="36.0" prefWidth="277.0"
              spacing="25.0">
            <children>
                <Button fx:id="cancelBtn" mnemonicParsing="false" prefHeight="30.0" prefWidth="125.0"
                        styleClass="button-cancel" text="Cancel">
                    <font>
                        <Font name="Arial" size="14.0"/>
                    </font>
                    <padding>
                        <Insets left="20.0" right="20.0"/>
                    </padding>
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Button>
                <Button fx:id="confirmBtn" mnemonicParsing="false" prefHeight="30.0" prefWidth="125.0"
                        styleClass="button-confirm" text="Confirm">
                    <font>
                        <Font name="Arial" size="14.0"/>
                    </font>
                    <padding>
                        <Insets left="20.0" right="20.0"/>
                    </padding>
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Button>
            </children>
        </HBox>
        <ImageView fitHeight="30.0" fitWidth="30.0" layoutX="463.0" layoutY="8.0"
                   onMouseClicked="#closeWindowConfirmation" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../../../icon/close.png"/>
            </image>
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </ImageView>
    </children>
</AnchorPane>
