                    <font>
                        <Font name="Arial Bold" size="14.0"/>
                    </font>
                </Label>
            </children>
        </HBox>
        <HBox alignment="CENTER" layoutX="656.0" layoutY="11.0" minWidth="90.0" prefWidth="125.0">
            <children>
                <Label fx:id="timeLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="20.0" layoutY="36.0"
                       maxWidth="120.0" minWidth="80.0" text="12:09 AM" textAlignment="CENTER" wrapText="true">
                    <font>
                        <Font name="Arial Bold" size="14.0"/>
                    </font>
                </Label>
            </children>
        </HBox>
        <HBox fx:id="buttonContainer" alignment="CENTER" prefWidth="250.0" spacing="20.0"
              stylesheets="@../../../../style/component/button.css"/>
    </children>
    <padding>
        <Insets left="20.0" right="20.0"/>
    </padding>
</HBox>
