      fx:controller="com.econnect.barangaymanagementapp.controller.utilitydepartment.table.RequestRowController">
    <children>
        <HBox alignment="CENTER" layoutX="10.0" layoutY="10.0" minWidth="90.0" prefWidth="125.0">
            <children>
                <Label fx:id="requestIdLabel" alignment="CENTER" contentDisplay="CENTER" maxWidth="120.0"
                       minWidth="80.0" text="0012345-2024-1000" textAlignment="CENTER" wrapText="true">
                    <font>
                        <Font name="Arial Bold" size="14.0"/>
                    </font>
                </Label>
            </children>
        </HBox>
        <HBox alignment="CENTER" layoutX="30.0" layoutY="10.0" minWidth="90.0" prefWidth="125.0" HBox.hgrow="ALWAYS">
            <children>
                <Label fx:id="residentIdLabel" alignment="CENTER" contentDisplay="CENTER" maxWidth="120.0"
                       minWidth="80.0" text="0012345-2024" textAlignment="CENTER" wrapText="true">
                    <font>
                        <Font name="Arial Bold" size="14.0"/>
                    </font>
                </Label>
            </children>
        </HBox>
        <HBox alignment="CENTER" layoutX="240.0" layoutY="10.0" minWidth="90.0" prefWidth="125.0" HBox.hgrow="ALWAYS">
