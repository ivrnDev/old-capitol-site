                <Label fx:id="requestTypeLabel" alignment="CENTER" contentDisplay="CENTER" maxWidth="120.0"
                       minWidth="80.0" text="Indigency" textAlignment="CENTER" wrapText="true">
                    <font>
                        <Font name="Arial Bold" size="14.0"/>
                    </font>
                </Label>
            </children>
        </HBox>
        <HBox alignment="CENTER" layoutX="871.0" layoutY="11.0" minWidth="90.0" prefWidth="125.0" HBox.hgrow="ALWAYS">
            <children>
                <Label fx:id="statusLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="20.0" layoutY="36.0"
